# API
APP_MODULE=main:app
APP_HOST=0.0.0.0
APP_PORT=8000
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=*

# Base de datos (obligatoria en runtime)
DATABASE_URL=postgresql+psycopg2://calculadora:calculadora@db:5432/calculadora
DB_WAIT_TIMEOUT=60

# Decision/risk config
MIN_MODEL_PROBABILITY=0.20
MIN_SIGNAL_DELTA=0.02
MIN_ACTIONABLE_ODDS=1.05
MIN_EV=0.00
MIN_CONFIDENCE=0.00
MAX_MARKET_VOLATILITY=0.55
KELLY_FRACTION=0.25
MAX_STAKE_UNITS=0.05
FLAT_STAKE_UNITS=0.01

# Calibration config
CALIBRATION_METHOD=builtin
CALIBRATOR_PATH=./artifacts/calibrator.json

# Local compose postgres defaults
POSTGRES_DB=calculadora
POSTGRES_USER=calculadora
POSTGRES_PASSWORD=calculadora
POSTGRES_PORT=5432
